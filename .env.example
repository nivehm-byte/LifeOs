# =============================================================
# LifeOS — Environment Variable Reference
# =============================================================
# This file is committed to version control.
# Copy it to .env.local, fill in every value, then never commit
# .env.local (it is gitignored).
#
# Variable naming:
#   NEXT_PUBLIC_*  Bundled into the browser — never put secrets here
#   (everything else is server-only — Node.js / Vercel Functions)
#
# Vercel setup:
#   Project Settings → Environment Variables
#   Select the environments each variable applies to
#   (Production / Preview / Development)
# =============================================================


# =============================================================
# SUPABASE                                                required
# Dashboard → Project Settings → API
# =============================================================
# The URL and anon key are safe to expose in the browser; RLS is
# the guard. The service role key bypasses RLS — never expose it.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>


# =============================================================
# GOOGLE CALENDAR                                 required (Phase 3)
# console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# =============================================================
# Required scopes: https://www.googleapis.com/auth/calendar.readonly
# Authorised redirect URI: https://<your-domain>/api/calendar/callback

GOOGLE_CLIENT_ID=<oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<oauth-client-secret>
GOOGLE_REDIRECT_URI=https://<your-domain>/api/calendar/callback


# =============================================================
# TELEGRAM BOT                                       required (Phase 2)
# Create via @BotFather → /newbot
# =============================================================
# 1. Create bot with @BotFather, copy the token.
# 2. Generate a webhook secret:  openssl rand -hex 32
# 3. After deployment, register the webhook once:
#   curl -X POST https://api.telegram.org/bot<TOKEN>/setWebhook \
#        -H 'Content-Type: application/json' \
#        -d '{"url":"https://<your-domain>/api/telegram/webhook","secret_token":"<TELEGRAM_WEBHOOK_SECRET>"}'
# 4. Create a "documents" Storage bucket in Supabase Dashboard → Storage.
#    Set it to private (RLS enforced).

TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_WEBHOOK_SECRET=<hex-secret-same-as-used-in-setWebhook>


# =============================================================
# AI APIS                                         required (Phase 2)
# =============================================================
# Gemini → briefing summarisation   aistudio.google.com/app/apikey
# Anthropic → Telegram NLP parsing  console.anthropic.com/settings/keys

GEMINI_API_KEY=<gemini-api-key>
ANTHROPIC_API_KEY=<anthropic-api-key>


# =============================================================
# WEB PUSH — VAPID                                        required
# =============================================================
# Generate a key pair once per project:
#   npx web-push generate-vapid-keys
#
# The public key is bundled with client code (safe to expose).
# The private key signs push payloads — server-only.
# VAPID_SUBJECT identifies the push sender (must be mailto: or https:).

NEXT_PUBLIC_VAPID_PUBLIC_KEY=<base64url-public-key>
VAPID_PRIVATE_KEY=<base64url-private-key>
VAPID_SUBJECT=mailto:your@email.com


# =============================================================
# APP URL                                                 required
# =============================================================
# Full origin of the deployed app, no trailing slash.
# Used for absolute URLs in OAuth callbacks, open-graph tags, etc.
# Set to your production domain on Vercel; localhost:3000 for dev.

NEXT_PUBLIC_APP_URL=https://<your-project>.vercel.app


# =============================================================
# CRON SECRET                                            required
# =============================================================
# Shared secret that protects every scheduled API endpoint:
#   /api/briefing/generate
#   /api/tasks/escalate
#   /api/push/briefing
#
# Must match in two places:
#   1. This env var (set in Vercel Environment Variables)
#   2. The x-cron-secret request header Vercel sends with each job
#      Project Settings → Crons → each job → Add header:
#        Name:  x-cron-secret
#        Value: <same secret>
#
# Generate: openssl rand -hex 32

CRON_SECRET=<hex-secret>
