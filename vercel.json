{
  "framework": "nextjs",

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        {
          "key":   "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), push=(self), notifications=(self)"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/workbox-(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],

  "crons": [
    { "path": "/api/briefing/generate",       "schedule": "15 3 * * *" },
    { "path": "/api/tasks/escalate",           "schedule": "20 3 * * *" },
    { "path": "/api/push/briefing?slot=0530", "schedule": "30 3 * * *" },
    { "path": "/api/push/briefing?slot=0600", "schedule": "0 4 * * *"  },
    { "path": "/api/push/briefing?slot=0630", "schedule": "30 4 * * *" },
    { "path": "/api/push/briefing?slot=0700", "schedule": "0 5 * * *"  },
    { "path": "/api/push/briefing?slot=0730", "schedule": "30 5 * * *" }
  ]
}
